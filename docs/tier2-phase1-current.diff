+            Type::Prim(p) => match p {
+                Prim::I8 => "i8",
+                Prim::I16 => "i16",
+                Prim::I32 => "i32",
+                Prim::I64 => "i64",
+                Prim::Usize => "usize",
+                Prim::F32 => "f32",
+                Prim::F64 => "f64",
+                Prim::Bool => "bool",
+                Prim::Char => "char",
+            }
+            .to_string(),
+            Type::Named { path, .. } => {
+                let simple = path.rsplit(['.', ':']).next().unwrap_or(path);
+                self.resolve_type_name(simple)
+            }
+            _ => crate::stubs::UNKNOWN.to_string(),
+        }
+    }
