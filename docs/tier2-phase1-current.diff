+    /// Is `tn` a RAW (no-type-arg) arity-1 collection type node?
+    fn is_raw_arity1_collection(&self, tn: NodeId) -> bool {
+        match self.arena.kind(tn) {
+            Node::ClassOrInterfaceType { name, type_args, .. } => {
