#[derive(Clone)]
struct A {
}

impl A {

    fn  m(&self)   {
         {
             let mut i: i32 = 10;
            loop  {
                {
                    println!("{}", format!("i: {}", i));
                    if i > 100 {
                        break;
                    }

                }
                i += 1;
             }
         }

        ;
    }
}

