/// @java A
#[derive(Clone, Default)]
struct A {
}

impl A {

    /// @java A#m
    fn m(&self)   {
         let mut i: i32 = 0;
        loop {
            println!("{}", format!("i: {}", i));
            if i > 100 {
                break;
            }
            else {
                i += 1;
            }
        }

        ;
    }
}

