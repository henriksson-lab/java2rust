// package com::example;

/// @java com.example.Calc
#[derive(Clone, Default)]
pub struct Calc {
    /// @java com.example.Calc#total
    total: i32,
}

impl Calc {

    /// @java com.example.Calc#addAll
    pub fn add_all(&mut self,  xs: &Vec<i32>) -> i32  {
         {
             let mut i: i32 = 0;
            while i < xs.len() {
                {
                    self.total += xs[(i) as usize];
                }
                i += 1;
             }
         }

        if self.total > 100 {
            return 100;
        } else {
            return self.total;
        }
    }

    /// @java com.example.Calc#half
    fn half( v: f64) -> f64  {
        return v / 2.0;
    }

    pub fn new() -> Self { Default::default() }
}

