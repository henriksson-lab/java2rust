/// @java A
#[derive(Clone, Default, PartialEq, Eq, Hash)]
pub struct A {
}

impl A {

    /// @java A#m
    pub fn m(&self)   {
         {
             let mut i: i32 = 10;
            while i < 100 {
                {
                    println!("{}", format!("i: {}", i));
                }
                i += 1;
             }
         }

        ;
    }

    pub fn new() -> Self { Default::default() }
}

