/// @java A
#[derive(Clone, Default)]
struct A {
}

impl A {

    /// @java A#m
    fn m(&self)   {
         {
             let mut i: i32 = 10;
            while i < 100 {
                {
                    println!("{}", format!("i: {}", i));
                }
                i += 1;
             }
         }

        ;
    }
}

