/// @java X
#[derive(Clone, Default, PartialEq, Eq, Hash)]
pub struct X {
}

impl X {

    pub fn new() -> Self { Default::default() }
}

/// @java X.A
#[derive(Clone, Copy, PartialEq, Eq, Hash, Debug, Default)]
pub enum A {
    #[default]
    AA,
}
impl std::fmt::Display for A { fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result { write!(f, "{:?}", self) } }


/// @java X.B
#[derive(Clone, Copy, PartialEq, Eq, Hash, Debug, Default)]
pub enum B {
    #[default]
    BB,
}
impl std::fmt::Display for B { fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result { write!(f, "{:?}", self) } }


